# frozen_string_literal: true

current_pwd = Dir.pwd # Current directory of the user when running the script
project_path = File.expand_path('..', __dir__) # Determine as the project root directory

# Load the core app logic
$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))

# Ensure bundler can read what gems to be loaded
Dir.chdir(project_path)

require 'bundler/setup'
require 'app'

# Put back to where user used to be
Dir.chdir(current_pwd)

# Bootstrap
App.start
